{
  "name": "@letta-ai/muscle-memory",
  "version": "0.6.0",
  "description": "A Letta Code mod that watches an agent's real tool-use, distills recurring fixes into quality-gated SKILL.md playbooks, updates existing skills instead of duplicating them, and prunes the ones that don't earn their context \u2014 a skill library that maintains itself.",
  "author": "Adrian with Kev and Mack",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "letta-package",
    "letta-mod",
    "letta-code",
    "agent-skills",
    "skill-distillation",
    "self-improving-agents",
    "procedural-memory",
    "complementary-learning-systems"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/letta-ai/mods.git",
    "directory": "packages/muscle-memory"
  },
  "files": [
    "MOD.md",
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "mods"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "letta": {
    "manifestVersion": 1,
    "mods": [
      "./mods/index.ts"
    ],
    "capabilities": [
      "tools",
      "commands",
      "events.tools",
      "events.lifecycle",
      "events.llm",
      "events.compact",
      "events.turns",
      "ui.panels",
      "permissions"
    ],
    "engines": {
      "lettaCodeCli": ">=0.27.18"
    }
  },
  "scripts": {
    "test": "bun test test/",
    "transpile": "bun build mods/index.ts --target node --outfile /tmp/muscle-memory.build.js",
    "verify": "npm run transpile && npm run test"
  },
  "contributors": [
    {
      "name": "Kev (Constellation agent)",
      "url": "https://github.com/adrianchan94"
    },
    {
      "name": "Mack (local Letta agent)",
      "url": "https://github.com/adrianchan94"
    }
  ]
}
