    "README.md",
    "MOD.md",
    "mods"
  ],
  "letta": {
    "manifestVersion": 1,
    "mods": ["./mods/index.ts"],
    "capabilities": ["commands", "events.lifecycle"],
    "engines": {
      "lettaCodeCli": ">=0.27.14"
    }
