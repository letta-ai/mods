{
  "name": "@letta-ai/secrets-scrubber",
  "version": "0.1.0",
  "description": "A Letta Code mod that redacts detected secrets from tool results before they enter conversation history.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "letta-package",
    "letta-mod",
    "letta-code",
    "secrets",
    "redaction",
    "security",
    "tool-output"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/letta-ai/mods.git",
    "directory": "packages/secrets-scrubber"
  },
  "files": [
    "README.md",
    "MOD.md",
    "mods"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sanity-labs/secret-scan": "1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  },
  "letta": {
    "manifestVersion": 1,
    "mods": [
      "./mods/index.ts"
    ],
    "capabilities": [
      "events.tools"
    ],
    "engines": {
      "lettaCodeCli": ">=0.27.14"
    }
  }
}
