{
  "name": "@letta-ai/mod-analysis-mode",
  "version": "0.1.0",
  "description": "Example Letta Code mod package that adds phrase-triggered diagnostic analysis mode.",
  "author": "cpacker",
  "license": "Apache-2.0",
  "type": "module",
  "keywords": [
    "letta-package",
    "letta-mod",
    "letta-code",
    "analysis-mode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/letta-ai/mods.git",
    "directory": "packages/analysis-mode"
  },
  "files": [
    "README.md",
    "MOD.md",
    "mods"
  ],
  "letta": {
    "manifestVersion": 1,
    "mods": ["./mods/index.ts"],
    "capabilities": ["events.turns"],
    "engines": {
      "lettaCodeCli": ">=0.27.14"
    }
  }
}
